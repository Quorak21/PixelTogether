# =============================================================================
# PixelTogether — variables d'environnement (backend)
# =============================================================================
# Copier ce fichier vers .env en local, ou définir ces variables sur le VPS
# (fichier .env monté dans le container, ou variables injectées au démarrage).
#
# Le fichier .env réel n'est jamais versionné (.gitignore).
# =============================================================================

# Port HTTP d'écoute de l'API (Express + Socket.io).
# En production Docker, le container expose 3000 ; le reverse proxy (nginx, etc.)
# route https://api.pixel.dokkcorp.ch vers ce port.
PORT=3000

# -----------------------------------------------------------------------------
# CORS & Socket.io — origines autorisées
# -----------------------------------------------------------------------------
# index.js construit la liste des origines autorisées ainsi :
#   - http://localhost:4200  (développement Angular, toujours inclus)
#   - FRONTEND_URL             (production, obligatoire en prod)
#   - FRONTEND_URL2            (optionnel : preview Vercel, second domaine, etc.)
#
# Sans FRONTEND_URL correcte, le navigateur bloque les requêtes depuis le
# frontend déployé (erreur CORS) et Socket.io ne se connecte pas.
#
# Production — frontend Vercel :
FRONTEND_URL=https://pixel-together.vercel.app

# Optionnel — décommenter si besoin d'une seconde origine (ex. preview Vercel) :
# FRONTEND_URL2=https://pixel-together-git-main-votre-equipe.vercel.app
